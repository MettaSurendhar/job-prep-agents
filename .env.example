# Copy this file to .env and fill in your own values.
# .env is git-ignored — your real keys never get committed.

# Which Ollama model to use — phi4-mini is a good default for 4GB+ VRAM.
OLLAMA_MODEL=phi4-mini:latest

# How long Ollama keeps the model loaded after last use, so back-to-back
# agent calls (and manual re-runs) stay fast instead of reloading every time.
OLLAMA_KEEP_ALIVE=30m

# Required only for the job_digest agent (Mon & Thu), which uses Ollama's
# hosted web search. Get a key at https://docs.ollama.com/api/authentication
OLLAMA_API_KEY=

# Optional — enables real embedded YouTube videos for DSA problems instead of
# just a search link. Get a free key via Google Cloud Console (YouTube Data API v3).
YOUTUBE_API_KEY=
